// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"context": "Workspace",
		"bindings": {
			"cmd-alt-c": [
				"agent::NewExternalAgentThread",
				{ "agent": { "custom": { "name": "claude-acp" } } },
			],
		},
	},
	{
		"context": "Editor && vim_mode == insert",
		"bindings": {
			// "j k": "vim::NormalBefore"
		},
	},
 {
  "context": "Workspace",
  "bindings": {
   "cmd-shift-c": "agent::ToggleFocus"
  }
 },
 {
  "context": "Workspace",
  "unbind": {
   "cmd-?": "agent::ToggleFocus"
  }
 },
 {
  "unbind": {
   "cmd-shift-c": "collab_panel::ToggleFocus"
  }
 },
 {
  "context": "KeymapEditor",
  "unbind": {
   "cmd-shift-c": "keymap_editor::CopyContext"
  }
 },
 {
  "context": "AgentPanel",
  "unbind": {
   "cmd-shift-e": "project_panel::ToggleFocus"
  }
 },
 {
  "context": "CollabPanel",
  "unbind": {
   "shift-enter": "collab_panel::ToggleSelectedChannelFavorite"
  }
 },
 {
  "context": "GitPanel && ChangesList && !GitBranchSelector",
  "unbind": {
   "escape": "git_panel::ToggleFocus"
  }
 },
 {
  "context": "Workspace",
  "unbind": {
   "ctrl-`": "terminal_panel::Toggle"
  }
 },
 {
  "context": "Workspace",
  "unbind": {
   "cmd-shift-d": "debug_panel::ToggleFocus"
  }
 },
 {
  "context": "Workspace",
  "bindings": {
   "cmd-shift-g": "git_panel::ToggleFocus"
  }
 },
 {
  "context": "Workspace",
  "unbind": {
   "ctrl-shift-g": "git_panel::ToggleFocus"
  }
 },
 {
  "context": "Workspace",
  "bindings": {
   "cmd-shift-o": "outline::Toggle"
  }
 },
 {
  "context": "BufferSearchBar",
  "unbind": {
   "cmd-shift-o": "outline::Toggle"
  }
 },
 {
  "context": "Editor && mode == full",
  "unbind": {
   "cmd-shift-o": "outline::Toggle"
  }
 }
]
